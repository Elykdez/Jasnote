{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jesnote: Build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\Jesnote.slnx",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Jesnote: Run",
      "type": "shell",
      "command": "${workspaceFolder}\\run.bat",
      "group": "test",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Jesnote: Run sample.json",
      "type": "shell",
      "command": "${workspaceFolder}\\run.bat",
      "args": [
        "${workspaceFolder}\\sample.json"
      ],
      "group": "test",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
